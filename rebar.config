{erl_opts, [
    debug_info,
    nowarn_unused_vars,
    warn_export_all,
    warn_unused_vars,
    warn_shadow_vars,
    {i, "apps/chat_core/include"}
]}.


{apps_dirs, ["apps"]}.

{deps, [
    {cowboy, "2.14.0"},
    {cowlib, "2.16.0"},
    {ranch, "2.2.0"},
    {jsx, "3.1.0"},
    {telemetry, "1.3.0"},
    {telemetry_poller, "1.2.0"}
]}.



%% EUNIT (unit tests inside src or compiled modules)
{eunit_opts, [verbose]}.

%% COMMON TEST (integration/system tests)
{ct_opts, [
    {dir, "apps/chat_core/test"},
    {dir, "apps/chat_api/test"}
]}.

{cover_enabled, true}.



{relx, [
    {release, {chat_system, "0.1.0"}, [
        kernel,
        stdlib,
        sasl,
        crypto,
        chat_core,
        chat_api
    ]},

    {mode, dev},

    {sys_config, "./config/sys.config"},
    {vm_args, "./config/vm.args"},

    {extended_start_script, true},
    {include_erts, true},
    {include_src, false}
]}.